{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"noEmit": false,
		"allowImportingTsExtensions": false,
		"declaration": true,
		"declarationMap": true,
		"emitDeclarationOnly": true,
		"outDir": "./dist",
		"rootDir": "./src",
		"composite": false,
		"types": ["node", "vite/client"]
	},
	"include": ["src/**/*.ts", "src/**/*.vue", "env.d.ts"],
	"exclude": ["src/**/*.test.ts", "src/**/*.spec.ts"]
}
